# InfraScope360 Agent Configuration
# Copy this file to .env and fill in the values

# URL base das Edge Functions do backend
AGENT_API_BASE_URL=https://akbosdbyheezghieiefz.supabase.co/functions/v1

# Intervalo padrão de heartbeat em segundos
AGENT_POLL_INTERVAL=60

# Caminho para o arquivo de estado persistente
AGENT_STATE_FILE=storage/state.json

# Código de ativação único (obtido no painel do InfraScope360)
# Formato: XXXX-XXXX-XXXX-XXXX
AGENT_ACTIVATION_CODE=XXXX-XXXX-XXXX-XXXX

# Supabase Realtime (para comandos remotos em tempo real)
SUPABASE_URL=https://akbosdbyheezghieiefz.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
